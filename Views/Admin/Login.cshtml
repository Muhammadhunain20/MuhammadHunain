@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login – Muhammad Hunain Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/portfolio.css" />
    <style>
        body { background: #06091A; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Inter', sans-serif; }
        .login-wrap { width: 100%; max-width: 420px; padding: 2rem; }
        .login-logo { text-align: center; margin-bottom: 2rem; }
        .login-logo .brand-mh { font-family: 'Space Grotesk', sans-serif; font-size: 2.5rem; font-weight: 700; background: linear-gradient(135deg, #7C6FFF, #00E5D4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .login-logo .brand-dot { color: #7C6FFF; font-size: 2.5rem; }
        .login-logo p { color: #7B8DB0; font-size: 0.9rem; margin-top: 0.25rem; }
        .login-card { background: #0C1023; border: 1px solid rgba(124,111,255,0.15); border-radius: 16px; padding: 2.5rem; box-shadow: 0 25px 60px rgba(0,0,0,0.5); }
        .login-title { font-family: 'Space Grotesk', sans-serif; color: #EEF2FF; font-size: 1.4rem; font-weight: 600; margin-bottom: 0.25rem; }
        .login-subtitle { color: #7B8DB0; font-size: 0.875rem; margin-bottom: 2rem; }
        .input-group-admin { position: relative; margin-bottom: 1.5rem; }
        .input-group-admin input { width: 100%; background: #111829; border: 1px solid rgba(124,111,255,0.2); border-radius: 10px; padding: 0.875rem 1rem 0.875rem 3rem; color: #EEF2FF; font-family: 'Inter', sans-serif; font-size: 0.95rem; transition: all 0.3s ease; outline: none; }
        .input-group-admin input:focus { border-color: #7C6FFF; box-shadow: 0 0 0 3px rgba(124,111,255,0.15); }
        .input-group-admin .input-icon { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #7B8DB0; pointer-events: none; }
        .input-group-admin .toggle-pw { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: #7B8DB0; cursor: pointer; background: none; border: none; }
        .input-group-admin .toggle-pw:hover { color: #7C6FFF; }
        .btn-admin-login { width: 100%; padding: 0.875rem; background: linear-gradient(135deg, #7C6FFF, #00E5D4); border: none; border-radius: 10px; color: white; font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.3s ease; letter-spacing: 0.02em; }
        .btn-admin-login:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(124,111,255,0.4); }
        .error-box { background: rgba(255,107,107,0.1); border: 1px solid rgba(255,107,107,0.3); border-radius: 8px; padding: 0.75rem 1rem; color: #FF6B6B; font-size: 0.875rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }
        .back-link { display: block; text-align: center; margin-top: 1.5rem; color: #7B8DB0; text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
        .back-link:hover { color: #7C6FFF; }
        .back-link i { margin-right: 0.4rem; }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-logo">
            <span class="brand-mh">MH</span><span class="brand-dot">.</span>
            <p>Portfolio Admin Portal</p>
        </div>
        <div class="login-card">
            <h2 class="login-title"><i class="fas fa-lock me-2" style="color:#7C6FFF;font-size:1.1rem;"></i>Admin Login</h2>
            <p class="login-subtitle">Enter your password to manage the portfolio.</p>

            @if (ViewBag.Error != null)
            {
                <div class="error-box">
                    <i class="fas fa-exclamation-circle"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Admin">
                @Html.AntiForgeryToken()
                <div class="input-group-admin">
                    <i class="fas fa-key input-icon"></i>
                    <input type="password" name="password" id="passwordInput"
                           placeholder="Enter admin password" required autofocus />
                    <button type="button" class="toggle-pw" onclick="togglePw()">
                        <i class="fas fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <button type="submit" class="btn-admin-login">
                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                </button>
            </form>

            <a href="/" class="back-link"><i class="fas fa-arrow-left"></i>Back to Portfolio</a>
        </div>
    </div>
    <script>
        function togglePw() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
</body>
</html>
