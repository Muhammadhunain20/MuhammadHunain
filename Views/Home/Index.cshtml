                    </div>
                    <div id="form-error" class="alert-error-custom d-none">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <span id="form-error-text"></span>
                    </div>

                    <form id="contactForm">
                        @Html.AntiForgeryToken()
