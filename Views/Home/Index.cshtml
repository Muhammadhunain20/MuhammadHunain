            <span class="section-label">Get to know me</span>
            <h2 class="section-title">About <span class="gradient-text">Me</span></h2>
            <div class="section-line"></div>
        </div>

        <div class="row align-items-start g-5">
            <!-- LEFT: Bio + Info -->
            <div class="col-lg-5" data-aos="fade-right" data-aos-delay="100">
                <div class="about-bio-card">
                    <p class="about-bio">
                        I'm a final-year Computer Science student at <strong>Muhammad Ali Jinnah University (MAJU)</strong>,
                        Karachi, with a CGPA of <strong>3.3</strong> and a last-semester GPA of <strong>3.75</strong>.
                        Originally from Tando Adam in interior Sindh, I moved to Karachi to pursue my passion for technology.
                    </p>
                    <p class="about-bio">
                        I specialize in building responsive, user-friendly web applications using
                        <strong>HTML/CSS/JS/Bootstrap</strong> on the frontend and <strong>ASP.NET MVC 8</strong>
                        with <strong>SQL Server</strong> on the backend. I've also deployed apps to Microsoft Azure.
                    </p>

                    <!-- Personal Info List -->
                    <ul class="info-list">
                        <li>
                            <span class="info-icon"><i class="fas fa-user-graduate"></i></span>
                            <span><strong>Degree:</strong> BS Computer Science (7th Sem)</span>
                        </li>
                        <li>
                            <span class="info-icon"><i class="fas fa-university"></i></span>
                            <span><strong>University:</strong> MAJU, Karachi</span>
                        </li>
                        <li>
                            <span class="info-icon"><i class="fas fa-map-marker-alt"></i></span>
                            <span><strong>Location:</strong> Karachi, Pakistan</span>
                        </li>
                        <li>
                            <span class="info-icon"><i class="fas fa-envelope"></i></span>
                            <span><strong>Email:</strong> hunni.khan0011&#64;gmail.com</span>
                        </li>
                        <li>
                            <span class="info-icon"><i class="fas fa-phone"></i></span>
                            <span><strong>Phone:</strong> +92 310 3188847</span>
                        </li>
                        <li>
                            <span class="info-icon"><i class="fas fa-briefcase"></i></span>
                            <span><strong>Status:</strong> <span class="status-badge">Open to Work</span></span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- RIGHT: Skills + Education -->
            <div class="col-lg-7" data-aos="fade-left" data-aos-delay="200">

                <!-- Skills -->
                <h3 class="subsection-title mb-4"><i class="fas fa-code me-2 text-accent"></i>Technical Skills</h3>
                <div class="skills-grid mb-5">
                    @{
                        var skills = new[]
                        {
                            new { Name = "HTML5 / CSS3", Icon = "fab fa-html5", Pct = 95, Color = "#E44D26" },
                            new { Name = "Bootstrap 5", Icon = "fab fa-bootstrap", Pct = 90, Color = "#7952B3" },
                            new { Name = "JavaScript (ES6+)", Icon = "fab fa-js-square", Pct = 78, Color = "#F7DF1E" },
                            new { Name = "ASP.NET MVC 8", Icon = "fab fa-microsoft", Pct = 72, Color = "#7C6FFF" },
                            new { Name = "SQL Server / MySQL", Icon = "fas fa-database", Pct = 75, Color = "#00E5D4" },
                            new { Name = "Git & GitHub", Icon = "fab fa-github", Pct = 80, Color = "#FF6B6B" },
                            new { Name = "C++ / OOP", Icon = "fas fa-terminal", Pct = 70, Color = "#00D4AA" },
                            new { Name = "React.js (Learning)", Icon = "fab fa-react", Pct = 40, Color = "#61DAFB" },
                        };
                    }
                    @foreach (var skill in skills)
                    {
                        <div class="skill-item">
                            <div class="skill-header">
                                <span class="skill-name"><i class="@skill.Icon me-2"></i>@skill.Name</span>
                                <span class="skill-pct">@skill.Pct%</span>
                            </div>
                            <div class="skill-bar-bg">
                                <div class="skill-bar-fill" data-width="@skill.Pct"
                                     style="--bar-color: @skill.Color"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Education + Certifications -->
                <h3 class="subsection-title mb-4"><i class="fas fa-graduation-cap me-2 text-accent"></i>Education & Certifications</h3>
                <div class="edu-timeline">
                    <div class="edu-item" data-aos="fade-up" data-aos-delay="100">
                        <div class="edu-dot"></div>
                        <div class="edu-card">
                            <span class="edu-year">2023 – Present</span>
                            <h5 class="edu-degree">BS Computer Science</h5>
                            <p class="edu-school"><i class="fas fa-university me-1"></i>Muhammad Ali Jinnah University, Karachi</p>
                            <p class="edu-detail">CGPA: 3.3 &nbsp;|&nbsp; Last Semester GPA: 3.75 &nbsp;|&nbsp; 7th Semester</p>
                        </div>
                    </div>
                    <div class="edu-item" data-aos="fade-up" data-aos-delay="150">
                        <div class="edu-dot cert"></div>
                        <div class="edu-card">
                            <span class="edu-year">2024</span>
                            <h5 class="edu-degree">The Complete Front-End Web Development Bootcamp</h5>
                            <p class="edu-school"><i class="fas fa-certificate me-1"></i>Udemy</p>
                        </div>
                    </div>
                    <div class="edu-item" data-aos="fade-up" data-aos-delay="200">
                        <div class="edu-dot cert"></div>
                        <div class="edu-card">
                            <span class="edu-year">2025</span>
                            <h5 class="edu-degree">Networking Essentials & Industrial Networking</h5>
                            <p class="edu-school"><i class="fas fa-certificate me-1"></i>Cisco Networking Academy</p>
                        </div>
                    </div>
                    <div class="edu-item" data-aos="fade-up" data-aos-delay="200">
                        <div class="edu-dot cert"></div>
                        <div class="edu-card">
                            <span class="edu-year">2026</span>
                            <h5 class="edu-degree">Web Development</h5>
                            <p class="edu-school"><i class="fas fa-certificate me-1"></i>Muhammad Ali Jinnah Univeristy</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     PROJECTS SECTION
============================================================ -->
<section id="projects" class="section-padding section-dark">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <span class="section-label">What I've built</span>
            <h2 class="section-title">My <span class="gradient-text">Projects</span></h2>
            <div class="section-line"></div>
        </div>

        <div class="row g-4" id="projects-grid">
            @if (Model != null && Model.Any())
            {
                @foreach (var project in Model)
                {
                    var tags = project.Technologies.Split(',').Select(t => t.Trim()).ToArray();
                    <div class="col-lg-6 col-xl-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="project-card" data-tilt data-tilt-max="6" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.1">
                            <!-- Card Image / Gradient Header -->
                            <div class="project-img-area @(project.IsFeatured ? "featured-project" : "")">
                                @if (!string.IsNullOrEmpty(project.ImageUrl))
                                {
                                    <img src="@project.ImageUrl" alt="@project.Title" class="project-screenshot" />
                                }
                                else
                                {
                                    <div class="project-gradient-bg">
                                        <div class="project-title-overlay">
                                            <i class="fas fa-code project-icon"></i>
                                            <span>@project.Title.Split('–')[0].Trim()</span>
                                        </div>
                                    </div>
                                }
                                @if (project.IsFeatured)
                                {
                                    <span class="featured-badge"><i class="fas fa-star me-1"></i>Featured</span>
                                }
                            </div>

                            <!-- Card Body -->
                            <div class="project-body">
                                <h4 class="project-name">@project.Title</h4>
                                <p class="project-desc">@project.Description</p>

                                <!-- Tech Tags -->
                                <div class="tech-tags mb-3">
                                    @foreach (var tag in tags.Take(5))
                                    {
                                        <span class="tech-tag">@tag</span>
                                    }
                                    @if (tags.Length > 5)
                                    {
                                        <span class="tech-tag">+@(tags.Length - 5) more</span>
                                    }
                                </div>

                                <!-- Action Buttons -->
                                <div class="project-actions">
                                    @if (!string.IsNullOrEmpty(project.LiveUrl))
                                    {
                                        <a href="@project.LiveUrl" target="_blank" class="btn btn-live">
                                            <i class="fas fa-external-link-alt me-1"></i>Live Demo
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(project.GitHubUrl))
                                    {
                                        <a href="@project.GitHubUrl" target="_blank" class="btn btn-code">
                                            <i class="fab fa-github me-1"></i>View Code
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="fas fa-folder-open fa-3x text-muted mb-3 d-block"></i>
                    <p class="text-muted">No projects yet. Add some from the Admin panel.</p>
                </div>
            }
        </div>

        <!-- GitHub CTA -->
        <div class="text-center mt-5" data-aos="fade-up">
            <a href="https://github.com/muhammadhunain20" target="_blank" class="btn btn-outline-custom">
                <i class="fab fa-github me-2"></i>See More on GitHub
            </a>
        </div>
    </div>
</section>

