                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary-custom w-100" id="submitBtn">
                                    <i class="fas fa-paper-plane me-2"></i>Send Message
                                    <span class="btn-loader d-none" id="btnLoader">
                                        <i class="fas fa-spinner fa-spin ms-2"></i>
                                    </span>
                                </button>
                            </div>
                        </div>
